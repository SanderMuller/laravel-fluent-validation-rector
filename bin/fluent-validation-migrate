#!/usr/bin/env php
<?php declare(strict_types=1);

/**
 * Standalone source-text migrator for the main-package `1.7.x → 1.8.1` upgrade
 * on Filament+Livewire components. Operates purely on file bytes — no class
 * autoload, no Rector, no PhpParser. This is important: upgrading to `1.8.1`
 * puts Filament+Livewire classes using `HasFluentValidation` into a fatal-at-
 * load state (method-collision trait composition), so any AST-based tool that
 * autoloads the class during analysis aborts before it can fix the problem.
 * This script deliberately never touches the autoloader.
 *
 * What it does:
 *
 * 1. Walks the given paths (or `app/` by default) for `.php` files.
 * 2. For each file: if the text contains BOTH `HasFluentValidation(ForFilament)?`
 *    AND a Filament form trait (`InteractsWithForms` / `InteractsWithSchemas`),
 *    rewrites to the 1.8.1-correct shape:
 *    - Top-level import swapped to `HasFluentValidationForFilament` (if not
 *      already there).
 *    - Trait-use line swapped to the Filament variant (if it was plain).
 *    - 4-method `insteadof` adaptation block inserted if missing.
 *
 * 3. Leaves the `$this->validate(...)` / `$this->validateOnly(...)` call sites
 *    alone — the 1.8.1 trait overrides those standard names, so call sites
 *    remain correct without edits.
 *
 * Usage:
 *
 *     vendor/bin/fluent-validation-migrate                    # walk app/
 *     vendor/bin/fluent-validation-migrate app/ src/          # custom paths
 *     vendor/bin/fluent-validation-migrate --dry-run app/     # preview, no write
 *
 * Exit codes: 0 on success (including "no changes needed"), 1 on IO error.
 */

const FILAMENT_NEEDLES = ['InteractsWithForms', 'InteractsWithSchemas'];
const INSTEADOF_METHODS = ['validate', 'validateOnly', 'getRules', 'getValidationAttributes'];

$args = array_slice($argv, 1);
$dryRun = false;
$paths = [];

foreach ($args as $arg) {
    if ($arg === '--dry-run' || $arg === '-n') {
        $dryRun = true;

        continue;
    }

    if ($arg === '--help' || $arg === '-h') {
        fwrite(STDOUT, trim((string) file_get_contents(__FILE__), " \t\n*/") . "\n");
        exit(0);
    }

    $paths[] = $arg;
}

if ($paths === []) {
    $paths = ['app'];
}

$filesChanged = 0;
$filesScanned = 0;

foreach ($paths as $path) {
    if (! file_exists($path)) {
        fwrite(STDERR, "warning: path does not exist: {$path}\n");

        continue;
    }

    foreach (iteratePhpFiles($path) as $file) {
        ++$filesScanned;

        $original = file_get_contents($file);

        if ($original === false) {
            fwrite(STDERR, "error: could not read {$file}\n");
            exit(1);
        }

        $rewritten = rewrite($original);

        if ($rewritten === null || $rewritten === $original) {
            continue;
        }

        ++$filesChanged;

        if ($dryRun) {
            fwrite(STDOUT, "would change: {$file}\n");

            continue;
        }

        if (file_put_contents($file, $rewritten) === false) {
            fwrite(STDERR, "error: could not write {$file}\n");
            exit(1);
        }

        fwrite(STDOUT, "changed: {$file}\n");
    }
}

fwrite(STDOUT, sprintf(
    "%s %d file%s across %d scanned.\n",
    $dryRun ? 'Would change' : 'Changed',
    $filesChanged,
    $filesChanged === 1 ? '' : 's',
    $filesScanned,
));

exit(0);

/**
 * @return iterable<string>
 */
function iteratePhpFiles(string $path): iterable
{
    if (is_file($path)) {
        if (str_ends_with($path, '.php')) {
            yield $path;
        }

        return;
    }

    $iterator = new RecursiveIteratorIterator(
        new RecursiveDirectoryIterator($path, RecursiveDirectoryIterator::SKIP_DOTS),
    );

    foreach ($iterator as $file) {
        if ($file instanceof SplFileInfo && $file->isFile() && $file->getExtension() === 'php') {
            yield $file->getPathname();
        }
    }
}

/**
 * Returns the rewritten text, or null if the file doesn't need changes.
 * Pure function: given a text blob, decides whether a migration applies and
 * produces the migrated text. All decision-making is source-text: no
 * reflection, no autoload, no PhpParser.
 */
function rewrite(string $source): ?string
{
    $filamentNeedle = detectFilamentNeedle($source);

    if ($filamentNeedle === null) {
        return null;
    }

    $hasPlainImport = preg_match('/^use\s+SanderMuller\\\\FluentValidation\\\\HasFluentValidation\s*;/m', $source) === 1;
    $hasFilamentImport = preg_match('/^use\s+SanderMuller\\\\FluentValidation\\\\HasFluentValidationForFilament\s*;/m', $source) === 1;

    if (! $hasPlainImport && ! $hasFilamentImport) {
        return null;
    }

    $hasInsteadof = hasFilamentInsteadofBlock($source, $filamentNeedle);

    if ($hasFilamentImport && ! $hasPlainImport && $hasInsteadof) {
        return null;
    }

    $result = $source;

    if ($hasPlainImport && ! $hasFilamentImport) {
        $result = (string) preg_replace(
            '/^use\s+SanderMuller\\\\FluentValidation\\\\HasFluentValidation\s*;/m',
            'use SanderMuller\\FluentValidation\\HasFluentValidationForFilament;',
            $result,
            1,
        );
    } elseif ($hasPlainImport && $hasFilamentImport) {
        $result = (string) preg_replace(
            '/^use\s+SanderMuller\\\\FluentValidation\\\\HasFluentValidation\s*;\r?\n/m',
            '',
            $result,
            1,
        );
    }

    $result = swapInClassTraitUse($result);

    if (! $hasInsteadof) {
        $result = insertInsteadofBlock($result, $filamentNeedle);
    }

    return $result;
}

function detectFilamentNeedle(string $source): ?string
{
    foreach (FILAMENT_NEEDLES as $needle) {
        if (str_contains($source, $needle)) {
            return $needle;
        }
    }

    return null;
}

function hasFilamentInsteadofBlock(string $source, string $filamentNeedle): bool
{
    $methodsPattern = implode('|', INSTEADOF_METHODS);
    $pattern = sprintf(
        '/HasFluentValidationForFilament::(?:%s)\s+insteadof\s+%s/',
        $methodsPattern,
        preg_quote($filamentNeedle, '/'),
    );

    return preg_match($pattern, $source) === 1;
}

/**
 * Swap the in-class `use HasFluentValidation;` trait-use line to the Filament
 * variant. Uses a word-boundary match so we don't also rewrite nested
 * references like `HasFluentValidationForFilament` (which must stay).
 */
function swapInClassTraitUse(string $source): string
{
    return (string) preg_replace(
        '/^(\s*)use\s+HasFluentValidation\s*;/m',
        '$1use HasFluentValidationForFilament;',
        $source,
    );
}

/**
 * Rewrite `use HasFluentValidationForFilament;` → the same trait-use with a
 * 4-method `insteadof` adaptation block. Only the first match per class body
 * is touched — the script runs once per file and the consumer only ever needs
 * one adaptation block per class.
 */
function insertInsteadofBlock(string $source, string $filamentNeedle): string
{
    $block = sprintf(
        "use HasFluentValidationForFilament {\n        HasFluentValidationForFilament::validate insteadof %s;\n        HasFluentValidationForFilament::validateOnly insteadof %s;\n        HasFluentValidationForFilament::getRules insteadof %s;\n        HasFluentValidationForFilament::getValidationAttributes insteadof %s;\n    }",
        $filamentNeedle,
        $filamentNeedle,
        $filamentNeedle,
        $filamentNeedle,
    );

    return (string) preg_replace(
        '/^(\s*)use\s+HasFluentValidationForFilament\s*;/m',
        '$1' . $block,
        $source,
        1,
    );
}
